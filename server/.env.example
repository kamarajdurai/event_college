# Server Configuration
PORT=5000
NODE_ENV=development

# Firebase Admin SDK - Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Firebase Project (same as your frontend config)
FIREBASE_PROJECT_ID=clgevent-56d3a

# Email Configuration (optional - for sending ticket emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=EventHub <noreply@eventhub.com>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
